2. Müük kategooriate kaupa

SELECT 
    p.category,
    COUNT(*) AS myykide_arv,
    COUNT(DISTINCT p.product_id) AS unikaalseid_tooteid,
    SUM(s.quantity * COALESCE(s.unit_price, p.price)) AS kogumyuk,
    ROUND(AVG(p.price), 2) AS keskmine_hind
FROM sales s
JOIN products p ON s.product_id = p.product_id
GROUP BY p.category
HAVING SUM(s.quantity * COALESCE(s.unit_price, p.price)) > 30000
ORDER BY kogumyuk DESC;

