1. Müük kuude kaupa.

SELECT      DATE_TRUNC('month', sale_date) AS kuu,      COUNT(sale_id) AS tellimuste_arv,      SUM(total_price) AS kogukäive,      ROUND(AVG(total_price), 2) AS keskmine_tellimus    
FROM sales    
WHERE sale_date >= '2024-01-01'    
GROUP BY DATE_TRUNC('month', sale_date)    
ORDER BY kuu;  

