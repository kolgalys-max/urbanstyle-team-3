3. Kuised trendid CTE-ga

WITH kuu_myyk AS (
SELECT        DATE_TRUNC('month', sale_date) AS kuu,        SUM(total_price) AS käive      
FROM sales      
WHERE sale_date >= '2024-01-01'      GROUP BY DATE_TRUNC('month', sale_date)    )    
SELECT      kuu,      käive,      
LAG(käive) OVER (ORDER BY kuu) AS eelmine_kuu,      käive - LAG(käive) OVER (ORDER BY kuu) AS muutus    
FROM kuu_myyk    ORDER BY kuu; 

