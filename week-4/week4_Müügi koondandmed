2. Müük kategooriate kaupa

SELECT 
    p.category,
    COUNT(*) AS toodete_arv,
    SUM(s.total_price) AS kogumyuk,
    ROUND(AVG(p.retail_price), 2) AS keskmine_hind
FROM sales s
JOIN products p ON s.product_id = p.product_id
WHERE s.sale_date >= '2024-01-01' 
  AND s.sale_date < '2025-01-01'
GROUP BY p.category
HAVING SUM(s.total_price) > 300000     -- saab muuta (nt 200000 või 400000)
ORDER BY kogumyuk DESC;

--Tulemus

