| naiste_riided | 1025        | 342064.71 | 195.20        |

3. Kuised trendid CTE-ga

WITH kuu_myyk AS (
    SELECT 
        DATE_TRUNC('month', sale_date) AS kuu,
        SUM(total_price) AS käive
    FROM sales
    WHERE sale_date >= '2024-01-01' 
      AND sale_date < '2025-01-01'
    GROUP BY DATE_TRUNC('month', sale_date)
)
SELECT 
    kuu,
    ROUND(käive, 2) AS käive,
    ROUND(LAG(käive) OVER (ORDER BY kuu), 2) AS eelmine_kuu,
    ROUND(käive - LAG(käive) OVER (ORDER BY kuu), 2) AS muutus,
    ROUND(
        (käive - LAG(käive) OVER (ORDER BY kuu)) 
        / NULLIF(LAG(käive) OVER (ORDER BY kuu), 0) * 100, 
        2
    ) AS muutus_protsent
FROM kuu_myyk
ORDER BY kuu;

